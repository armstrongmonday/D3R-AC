# Copy this file to .env and fill in real values. .env is gitignored --
# never commit a real private key, seed phrase, or funded testnet key.
# See docs/deployment-guide.md's security checklist.

# --- Deploy keys (one per network you actually deploy to) --------------
# Fund this address with testnet TRX first:
#   Shasta faucet: https://www.trongrid.io/shasta
#   Nile faucet:   https://nileex.io/join/getJoinPage
TRON_PRIVATE_KEY_SHASTA=
TRON_PRIVATE_KEY_NILE=

# --- MultiSigAdmin config (required by migrations/2_deploy_d3rac.js) ---
# Comma-separated TRON addresses that will co-own the deployed
# MultiSigAdmin, which becomes D3RACHub's admin at the end of the
# migration. Use addresses you control separately from the deploy key
# above -- the whole point of a multisig is that the deploy key alone
# can no longer move funds or change disbursement conditions afterward.
MULTISIG_OWNERS=
MULTISIG_THRESHOLD=

# --- Optional ------------------------------------------------------------
# Whole-token amount minted to the deployer at D3RACToken construction.
# Leave at 0 and mint via hub.mintTokens once the Hub is wired instead,
# unless you specifically need supply to exist before that.
D3RAC_INITIAL_SUPPLY=0

# RiskRegistry's initial threshold, in docs/risk-model.md's fixed-point
# units. Leave at 0 and set it via hub.setRiskThreshold once deployed,
# unless you already know the real value you want at genesis.
RISK_THRESHOLD=0
