# Copy to .env and fill in. Never commit the real .env file (it's already
# in .gitignore). NFR-1: the feeder private key is a real operational
# secret — anyone holding it can push arbitrary H/E/V values on-chain for
# any registered community. Prefer a secrets manager / HSM in production;
# .env is for local development only.

# --- On-chain submission ---
D3RAC_FEEDER_PRIVATE_KEY=
D3RAC_HUB_ADDRESS=
D3RAC_TRON_FULL_NODE=https://api.shasta.trongrid.io

# --- Satellite / sensor source API keys ---
# NASA FIRMS (satellite active-fire detection, MODIS/VIIRS). Free key:
# https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_MAP_KEY=

# NASA EONET, USGS, and GDACS do not require API keys.

# --- Ops ---
D3RAC_ENV=development
